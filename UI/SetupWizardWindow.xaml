<Window x:Class="PointyPal.UI.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PointyPal.UI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PointyPal Setup"
        Height="680"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ShellBackgroundBrush}"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="WizardButton" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Margin" Value="8"/>
        </Style>

        <Style x:Key="PrimaryWizardButton" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Margin" Value="8"/>
        </Style>

        <Style x:Key="StepTitle" TargetType="TextBlock" BasedOn="{StaticResource HeroTitleStyle}">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="LineHeight" Value="38"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="StepSubTitle" TargetType="TextBlock" BasedOn="{StaticResource PageLeadStyle}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="LineHeight" Value="23"/>
            <Setter Property="Margin" Value="0,0,0,28"/>
        </Style>

        <Style x:Key="WizardFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource FeatureTitleStyle}">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="WizardInput" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource InputSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryAccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="WizInputChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Height="{TemplateBinding Height}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="WizInputChrome" Property="BorderBrush" Value="{StaticResource AccentBorderStrongBrush}"/>
                                <Setter TargetName="WizInputChrome" Property="Effect" Value="{StaticResource CyanGlowSoftEffect}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="WizInputChrome" Property="BorderBrush" Value="{StaticResource AccentBorderStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WizardPassword" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource InputSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryAccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="WizPassChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Height="{TemplateBinding Height}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="WizPassChrome" Property="BorderBrush" Value="{StaticResource AccentBorderStrongBrush}"/>
                                <Setter TargetName="WizPassChrome" Property="Effect" Value="{StaticResource CyanGlowSoftEffect}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="WizPassChrome" Property="BorderBrush" Value="{StaticResource AccentBorderStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border BorderBrush="{StaticResource AccentBorderBrush}"
            BorderThickness="1"
            CornerRadius="28"
            Background="{StaticResource CardGradientBrush}"
            Margin="16"
            Effect="{StaticResource PremiumCardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Border x:Name="SafeModeBanner"
                        Visibility="Collapsed"
                        Background="{StaticResource ErrorBrush}"
                        Padding="16,9"
                        CornerRadius="28,28,0,0">
                    <TextBlock Text="Running in Safe Mode" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Border>

                <Grid Margin="38,28,38,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="SetupProgressBar"
                                 Height="5"
                                 Maximum="7"
                                 Value="1"
                                 Background="{StaticResource SurfaceDeepBrush}"
                                 Foreground="{StaticResource ProgressFillBrush}"
                                 BorderThickness="0">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="3"
                                        Height="{TemplateBinding Height}">
                                    <Border x:Name="PART_Track" CornerRadius="3">
                                        <Border x:Name="PART_Indicator"
                                                Background="{TemplateBinding Foreground}"
                                                CornerRadius="3"
                                                HorizontalAlignment="Left"/>
                                    </Border>
                                </Border>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                    <TextBlock x:Name="StepCounterText"
                               Grid.Column="1"
                               Text="Step 1 of 7"
                               Margin="18,0,0,0"
                               Foreground="{StaticResource TextSecondarySoftBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="1" Margin="56,24,56,30">
                <StackPanel x:Name="StepWelcome" Visibility="Visible">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="170"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource StepTitle}" Text="Welcome to PointyPal"/>
                            <TextBlock Style="{StaticResource StepSubTitle}" Text="Let's get your private AI assistant ready to understand the screen and guide you with precision."/>
                        </StackPanel>
                        <controls:CoreNodeVisual Grid.Column="1" Width="150" Height="150" HorizontalAlignment="Right"/>
                    </Grid>

                    <UniformGrid Columns="2" Margin="-8,8,-8,0">
                        <Border Style="{StaticResource CompactFeatureCardStyle}">
                            <StackPanel>
                                <Border Style="{StaticResource FeatureIconTileStyle}" Margin="0,0,0,12">
                                    <TextBlock Text="&#xE720;" Style="{StaticResource FeatureIconGlyphStyle}"/>
                                </Border>
                                <TextBlock Text="Voice" Style="{StaticResource FeatureTitleStyle}"/>
                                <TextBlock Text="Ask naturally without hunting through UI." Style="{StaticResource MutedTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CompactFeatureCardStyle}">
                            <StackPanel>
                                <Border Style="{StaticResource FeatureIconTileStyle}" Margin="0,0,0,12">
                                    <TextBlock Text="&#xE7B3;" Style="{StaticResource FeatureIconGlyphStyle}"/>
                                </Border>
                                <TextBlock Text="Vision" Style="{StaticResource FeatureTitleStyle}"/>
                                <TextBlock Text="Use screen context when you explicitly ask." Style="{StaticResource MutedTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CompactFeatureCardStyle}">
                            <StackPanel>
                                <Border Style="{StaticResource FeatureIconTileStyle}" Margin="0,0,0,12">
                                    <TextBlock Text="&#xE72E;" Style="{StaticResource FeatureIconGlyphStyle}"/>
                                </Border>
                                <TextBlock Text="Private" Style="{StaticResource FeatureTitleStyle}"/>
                                <TextBlock Text="Route requests through your own Worker." Style="{StaticResource MutedTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CompactFeatureCardStyle}">
                            <StackPanel>
                                <Border Style="{StaticResource FeatureIconTileStyle}" Margin="0,0,0,12">
                                    <TextBlock Text="&#xE8B5;" Style="{StaticResource FeatureIconGlyphStyle}"/>
                                </Border>
                                <TextBlock Text="Fast" Style="{StaticResource FeatureTitleStyle}"/>
                                <TextBlock Text="Built for quick screen-aware assistance." Style="{StaticResource MutedTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>

                <StackPanel x:Name="StepVoiceCheck" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource StepTitle}" Text="Check your microphone"/>
                    <TextBlock Style="{StaticResource StepSubTitle}" Text="PointyPal needs microphone access for push-to-talk voice asks."/>

                    <Border Style="{StaticResource PremiumCardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="MicStatusText" Text="Detecting microphone..." Style="{StaticResource SectionHeaderStyle}" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                            <Border Height="40" Background="{StaticResource InputSurfaceBrush}" CornerRadius="14" Margin="0,0,0,18" BorderBrush="{StaticResource AccentBorderBrush}" BorderThickness="1">
                                <ProgressBar x:Name="MicLevelBar" Maximum="100" Value="0" Foreground="{StaticResource SuccessBrush}" Background="Transparent" BorderThickness="0">
                                    <ProgressBar.Template>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10" Height="{TemplateBinding Height}">
                                                <Border x:Name="PART_Track" CornerRadius="10">
                                                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="10" HorizontalAlignment="Left"/>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </ProgressBar.Template>
                                </ProgressBar>
                            </Border>
                            <Button x:Name="TestMicBtn" Content="Test Microphone" Style="{StaticResource WizardButton}" Click="TestMicBtn_Click" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Hold Right Ctrl to test microphone capture once ready." Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="StepWorkerLink" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource StepTitle}" Text="Link your Worker"/>
                    <TextBlock Style="{StaticResource StepSubTitle}" Text="Connect your private AI gateway for security and speed."/>

                    <Border Style="{StaticResource PremiumCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Worker Base URL" Style="{StaticResource WizardFieldLabel}"/>
                            <TextBox x:Name="WorkerUrlBox" Style="{StaticResource WizardInput}" Margin="0,0,0,18"/>

                            <TextBlock Text="Client Key" Style="{StaticResource WizardFieldLabel}"/>
                            <PasswordBox x:Name="WorkerKeyBox" Style="{StaticResource WizardPassword}" Margin="0,0,0,20"/>

                            <DockPanel>
                                <Button x:Name="CheckWorkerBtn" Content="Verify Connection" Style="{StaticResource PrimaryWizardButton}" Click="CheckWorkerBtn_Click" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="WorkerStatusText" Text="Not checked" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </DockPanel>
                            <TextBlock x:Name="WorkerDetailsText" Text="" FontSize="12" Margin="0,10,0,0" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Your Worker acts as a secure tunnel to AI providers like Claude." Style="{StaticResource MutedTextStyle}"/>
                </StackPanel>

                <StackPanel x:Name="StepProviderSetup" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource StepTitle}" Text="Provider settings"/>
                    <TextBlock Style="{StaticResource StepSubTitle}" Text="Configure how PointyPal listens and speaks."/>

                    <Border Style="{StaticResource PremiumCardStyle}" Padding="0">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <CheckBox x:Name="EnableVoiceInputCheck" IsChecked="True">
                                    <StackPanel Margin="10,0,0,0">
                                        <TextBlock Text="Enable Voice Interaction" Style="{StaticResource FeatureTitleStyle}"/>
                                        <TextBlock Text="Use your voice to ask questions about your screen." Style="{StaticResource MutedTextStyle}"/>
                                    </StackPanel>
                                </CheckBox>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}" BorderThickness="0">
                                <StackPanel>
                                    <CheckBox x:Name="EnableTtsCheck">
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Enable Voice Output (TTS)" Style="{StaticResource FeatureTitleStyle}"/>
                                            <TextBlock Text="PointyPal can speak answers back to you." Style="{StaticResource MutedTextStyle}"/>
                                        </StackPanel>
                                    </CheckBox>
                                    <Button x:Name="TestTtsBtn" Content="Test Voice Output" Style="{StaticResource WizardButton}" Click="TestTtsBtn_Click" Visibility="Collapsed" HorizontalAlignment="Left" Margin="10,18,0,0"/>
                                    <TextBlock x:Name="TtsStatusText" Text="" FontSize="12" Margin="10,10,0,0" Foreground="{StaticResource TextSecondarySoftBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="StepPrivacySettings" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource StepTitle}" Text="Privacy control"/>
                    <TextBlock Style="{StaticResource StepSubTitle}" Text="You decide what PointyPal remembers locally."/>

                    <Border Style="{StaticResource PremiumCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Privacy-safe defaults keep local artifacts off unless you enable them." Style="{StaticResource FeatureTitleStyle}" Margin="0,0,0,18"/>
                            <BulletDecorator Margin="0,0,0,10">
                                <BulletDecorator.Bullet><Ellipse Fill="{StaticResource SuccessBrush}" Width="7" Height="7" Margin="0,5,12,0"/></BulletDecorator.Bullet>
                                <TextBlock Text="Screenshots are only captured when you ask." Style="{StaticResource BodyTextStyle}"/>
                            </BulletDecorator>
                            <BulletDecorator Margin="0,0,0,10">
                                <BulletDecorator.Bullet><Ellipse Fill="{StaticResource SuccessBrush}" Width="7" Height="7" Margin="0,5,12,0"/></BulletDecorator.Bullet>
                                <TextBlock Text="No audio is recorded unless you hold the hotkey." Style="{StaticResource BodyTextStyle}"/>
                            </BulletDecorator>
                            <BulletDecorator Margin="0,0,0,22">
                                <BulletDecorator.Bullet><Ellipse Fill="{StaticResource SuccessBrush}" Width="7" Height="7" Margin="0,5,12,0"/></BulletDecorator.Bullet>
                                <TextBlock Text="History is stored only on this computer." Style="{StaticResource BodyTextStyle}"/>
                            </BulletDecorator>
                            <Button x:Name="ApplyPrivacyDefaultsBtn" Content="Accept Privacy Defaults" Style="{StaticResource PrimaryWizardButton}" Click="ApplyPrivacyDefaultsBtn_Click" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="StepHotkeyLearn" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource StepTitle}" Text="Master the hotkeys"/>
                    <TextBlock Style="{StaticResource StepSubTitle}" Text="The two daily shortcuts that make PointyPal feel instant."/>

                    <UniformGrid Columns="2" Margin="-8,0,-8,0">
                        <Border Style="{StaticResource FeatureCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Right Ctrl" Style="{StaticResource StatNumberStyle}" FontSize="24" HorizontalAlignment="Center"/>
                                <TextBlock Text="Voice Ask" Style="{StaticResource FeatureTitleStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Hold to talk. Release to send." Style="{StaticResource MutedTextStyle}" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource FeatureCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Ctrl + Space" Style="{StaticResource StatNumberStyle}" FontSize="24" HorizontalAlignment="Center"/>
                                <TextBlock Text="Quick Ask" Style="{StaticResource FeatureTitleStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Type a question directly." Style="{StaticResource MutedTextStyle}" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <TextBlock Text="Tip: Press Escape at any time to cancel." Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Center" Margin="0,28,0,0" FontStyle="Italic"/>
                </StackPanel>

                <StackPanel x:Name="StepFinishAndTest" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource StepTitle}" Text="You're all set"/>
                    <TextBlock Style="{StaticResource StepSubTitle}" Text="PointyPal is ready for a final end-to-end check."/>

                    <Border Style="{StaticResource PremiumCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Everything is configured and ready to go." Style="{StaticResource FeatureTitleStyle}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <Button x:Name="RunRealTestBtn" Content="Run End-to-End Test" Style="{StaticResource WizardButton}" Click="RunRealTestBtn_Click"/>
                                <Button x:Name="FinishBtn" Content="Start Using PointyPal" Style="{StaticResource PrimaryWizardButton}" Click="FinishBtn_Click" Width="210"/>
                            </StackPanel>

                            <Border x:Name="RealTestResultPanel" Background="{StaticResource CyanAccentSubtleBrush}" BorderBrush="{StaticResource AccentBorderBrush}" BorderThickness="1" Padding="16" CornerRadius="14" Visibility="Collapsed">
                                <TextBlock x:Name="RealTestResultText" Text="Test in progress..." Foreground="{StaticResource PrimaryAccentBrush}" FontWeight="SemiBold" TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <CheckBox x:Name="StartWithWindowsCheck" Content="Start PointyPal with Windows" IsChecked="True" HorizontalAlignment="Center" Margin="0,18,0,0"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource CommandBarBrush}"
                    Padding="34,18"
                    CornerRadius="0,0,28,28"
                    BorderBrush="{StaticResource AccentBorderBrush}"
                    BorderThickness="0,1,0,0">
                <DockPanel LastChildFill="False">
                    <Button x:Name="PrevBtn" Content="Back" Style="{StaticResource WizardButton}" Click="PrevBtn_Click" DockPanel.Dock="Left" Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Button x:Name="SkipBtn" Content="Skip for Now" Style="{StaticResource WizardButton}" Click="SkipBtn_Click" Margin="0,0,10,0"/>
                        <Button x:Name="NextBtn" Content="Continue" Style="{StaticResource PrimaryWizardButton}" Click="NextBtn_Click" Width="130"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
