<Window x:Class="PointyPal.UI.QuickAskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quick Ask" Height="332" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        PreviewKeyDown="QuickAskWindow_PreviewKeyDown">
    <Border Style="{StaticResource QuickAskShellStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="18" Height="18" Margin="0,1,10,0">
                        <Path Data="M3,3 L10.07,19.97 L12.58,12.58 L19.97,10.07 Z"
                              Stroke="{StaticResource PrimaryAccentBrush}"
                              StrokeThickness="2"
                              StrokeLineJoin="Round"/>
                    </Viewbox>
                    <StackPanel>
                        <TextBlock Text="Quick Ask" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Ask about your screen or type a quick question." Style="{StaticResource MutedTextStyle}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <Border x:Name="StatusPill" Grid.Column="1" Style="{StaticResource QuickAskStatusPillStyle}" VerticalAlignment="Top">
                    <TextBlock x:Name="StatusPillText" Text="READY" Foreground="{StaticResource PrimaryAccentBrush}" FontSize="10.5" FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <Border x:Name="ConfigNoticeBorder" Grid.Row="1" Style="{StaticResource QuickAskNoticeStyle}" Visibility="Collapsed" Margin="0,0,0,12">
                <TextBlock x:Name="ConfigNoticeText" Text="" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5" TextWrapping="Wrap"/>
            </Border>

            <Grid Grid.Row="2" MinHeight="116">
                <TextBox x:Name="InputTextBox"
                         Style="{StaticResource QuickAskInputTextBoxStyle}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         PreviewKeyDown="InputTextBox_PreviewKeyDown"
                         TextChanged="InputTextBox_TextChanged"/>
                <TextBlock x:Name="PlaceholderText"
                           Text="Ask PointyPal..."
                           Foreground="{StaticResource TextSecondarySoftBrush}"
                           FontSize="15"
                           Margin="17,14,17,0"
                           IsHitTestVisible="False"/>
            </Grid>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="ModeComboBox"
                          Grid.Column="0"
                          Width="126"
                          Style="{StaticResource QuickAskComboBoxStyle}"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Assist" Tag="Assist"/>
                    <ComboBoxItem Content="Point" Tag="Point"/>
                    <ComboBoxItem Content="Explain" Tag="Explain"/>
                    <ComboBoxItem Content="Summarize" Tag="Summarize"/>
                    <ComboBoxItem Content="Read Screen" Tag="ReadScreen"/>
                    <ComboBoxItem Content="Debug" Tag="Debug"/>
                    <ComboBoxItem Content="Translate" Tag="Translate"/>
                    <ComboBoxItem Content="No Point" Tag="NoPoint"/>
                </ComboBox>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <CheckBox x:Name="ScreenshotToggle" Content="Screen" ToolTip="Screenshot context" IsChecked="True" Style="{StaticResource QuickAskChipCheckBoxStyle}"/>
                    <CheckBox x:Name="UiAutomationToggle" Content="UI" ToolTip="UI context" IsChecked="True" Style="{StaticResource QuickAskChipCheckBoxStyle}"/>
                    <CheckBox x:Name="TtsToggle" Content="Voice" ToolTip="Voice output" IsChecked="True" Style="{StaticResource QuickAskChipCheckBoxStyle}"/>
                    <CheckBox x:Name="PointerToggle" Content="Point" ToolTip="Pointer guidance" IsChecked="True" Style="{StaticResource QuickAskChipCheckBoxStyle}" Margin="0"/>
                </StackPanel>
            </Grid>

            <Border x:Name="StatusMessageBorder" Grid.Row="4" Style="{StaticResource QuickAskInlineMessageStyle}" Visibility="Collapsed" Margin="0,12,0,0">
                <TextBlock x:Name="StatusTextBlock" Text="" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5" TextWrapping="Wrap"/>
            </Border>

            <Grid Grid.Row="5" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Enter: Ask   Esc: Close   Ctrl+Space: Open"
                           Foreground="{StaticResource TextSecondarySoftBrush}"
                           FontSize="10.5"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" Style="{StaticResource QuickAskGhostButtonStyle}"
                        Content="Cancel"
                        Click="CancelButton_Click"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="2" Style="{StaticResource QuickAskPrimaryButtonStyle}"
                        x:Name="SendButton"
                        Content="Ask"
                        Click="SendButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
