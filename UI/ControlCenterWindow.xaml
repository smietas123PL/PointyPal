<Window x:Class="PointyPal.UI.ControlCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PointyPal.UI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PointyPal Control Center" Height="720" Width="1020"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ShellBackgroundBrush}"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        WindowStyle="None"
        AllowsTransparency="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Area -->
        <Grid Grid.Row="0" Margin="24,20,24,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Width="24" Height="24" Margin="0,0,14,0">
                    <Path Data="M3,3 L10.07,19.97 L12.58,12.58 L19.97,10.07 Z" 
                          Stroke="{StaticResource PrimaryAccentBrush}" 
                          StrokeThickness="2"
                          StrokeLineJoin="Round"/>
                </Viewbox>
                <TextBlock Text="PointyPal" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                <Border Background="{StaticResource CyanAccentSubtleBrush}" CornerRadius="12" Padding="10,3" Margin="14,0,0,0">
                    <TextBlock Text="PREMIUM v2" Foreground="{StaticResource PrimaryAccentBrush}" FontSize="10" FontWeight="Bold"/>
                </Border>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="MinimizeBtn" Content="&#xE921;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource GhostButtonStyle}" Width="40" Height="40" Click="MinimizeBtn_Click" Margin="0,0,4,0"/>
                <Button x:Name="CloseBtn" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource GhostButtonStyle}" Width="40" Height="40" Click="CloseBtn_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="24,10,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Style="{StaticResource SidebarPanelStyle}" Margin="0,0,20,24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="SidebarList" Style="{StaticResource SidebarListStyle}" SelectionChanged="SidebarList_SelectionChanged">
                        <ListBoxItem Style="{StaticResource SidebarItemStyle}" IsSelected="True">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" Style="{StaticResource SidebarIconStyle}"/>
                                <TextBlock Text="Overview" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SidebarItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" Style="{StaticResource SidebarIconStyle}"/>
                                <TextBlock Text="Setup &amp; Worker" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SidebarItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE722;" Style="{StaticResource SidebarIconStyle}"/>
                                <TextBlock Text="Privacy &amp; Data" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{StaticResource SidebarItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE928;" Style="{StaticResource SidebarIconStyle}"/>
                                <TextBlock Text="Hotkeys" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="AdvancedSidebarItem" Style="{StaticResource SidebarItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE964;" Style="{StaticResource SidebarIconStyle}"/>
                                <TextBlock Text="Advanced Tools" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>

                    <Border Grid.Row="1" Background="{StaticResource SurfaceDeepBrush}" CornerRadius="18" Padding="16" Margin="4">
                        <StackPanel>
                            <TextBlock Text="System Status" Style="{StaticResource PageSectionTitleStyle}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="Engine Active" Style="{StaticResource MutedTextStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="Worker Ready" Style="{StaticResource MutedTextStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <TabControl x:Name="MainTabs" Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0">
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent"/>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- Page 1: Overview -->
                <TabItem>
                    <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
                        <Grid Style="{StaticResource PageContentStyle}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Hero Section -->
                            <Border Grid.Row="0" Style="{StaticResource HeroCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel VerticalAlignment="Center">
                                        <Border x:Name="HomeStatusBadge" Style="{StaticResource StatusBadgeStyle}" HorizontalAlignment="Left" Margin="0,0,0,14">
                                            <TextBlock x:Name="HomeStatusBadgeText" Text="ALL SYSTEMS NOMINAL" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryAccentBrush}"/>
                                        </Border>
                                        <TextBlock x:Name="HomeStatusTitle" Text="PointyPal is ready." Style="{StaticResource HeroTitleStyle}"/>
                                        <TextBlock x:Name="HomeStatusDescription" Text="Your private AI guide is waiting for your next voice or typed request." Style="{StaticResource PageLeadStyle}"/>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button x:Name="HomePrimaryBtn" Content="Open Quick Ask" Style="{StaticResource PrimaryButtonStyle}" Click="QuickAskBtn_Click" Margin="0,0,12,0"/>
                                            <Button x:Name="HomeSecondaryBtn" Content="Run Diagnostics" Style="{StaticResource SecondaryButtonStyle}" Click="RunFullValidationBtn_Click"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <controls:CoreNodeVisual Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <UniformGrid Grid.Row="1" Columns="4" Margin="-7,0,-7,18">
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <Ellipse x:Name="VoiceStatusDot" Fill="{StaticResource SuccessBrush}" Width="8" Height="8" HorizontalAlignment="Right"/>
                                        <TextBlock Text="VOICE" Style="{StaticResource StatLabelStyle}"/>
                                        <TextBlock Text="Live" Style="{StaticResource StatNumberStyle}" FontSize="24"/>
                                        <TextBlock Text="Right Ctrl Active" Style="{StaticResource MutedTextStyle}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <Ellipse x:Name="QuickAskStatusDot" Fill="{StaticResource SuccessBrush}" Width="8" Height="8" HorizontalAlignment="Right"/>
                                        <TextBlock Text="QUICK ASK" Style="{StaticResource StatLabelStyle}"/>
                                        <TextBlock Text="Ready" Style="{StaticResource StatNumberStyle}" FontSize="24"/>
                                        <TextBlock Text="Ctrl+Space Active" Style="{StaticResource MutedTextStyle}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <Ellipse x:Name="ScreenStatusDot" Fill="{StaticResource SuccessBrush}" Width="8" Height="8" HorizontalAlignment="Right"/>
                                        <TextBlock Text="VISION" Style="{StaticResource StatLabelStyle}"/>
                                        <TextBlock Text="Active" Style="{StaticResource StatNumberStyle}" FontSize="24"/>
                                        <TextBlock Text="DPI Aware: Yes" Style="{StaticResource MutedTextStyle}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <Ellipse x:Name="PointerStatusDot" Fill="{StaticResource SuccessBrush}" Width="8" Height="8" HorizontalAlignment="Right"/>
                                        <TextBlock Text="POINTER" Style="{StaticResource StatLabelStyle}"/>
                                        <TextBlock Text="Locked" Style="{StaticResource StatNumberStyle}" FontSize="24"/>
                                        <TextBlock Text="Visuals Calibrated" Style="{StaticResource MutedTextStyle}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Grid Grid.Row="2" Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="380"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource PremiumCardStyle}" Margin="0,0,20,0">
                                    <StackPanel>
                                        <TextBlock Text="Recent Interaction History" Style="{StaticResource SectionHeaderStyle}"/>
                                        <Border x:Name="EmptyUsagePanel" Visibility="Visible" Padding="40" Background="{StaticResource SurfaceDeepBrush}" CornerRadius="16">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="{StaticResource TextSecondarySoftBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                                <TextBlock Text="No interactions yet today." Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <!-- Real list would be here -->
                                        <ItemsControl x:Name="HistoryList" Visibility="Collapsed">
                                            <!-- ... -->
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource PremiumCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="System Usage" Style="{StaticResource SectionHeaderStyle}"/>
                                        <Border Style="{StaticResource SettingsRowCardStyle}">
                                            <DockPanel>
                                                <TextBlock Text="Interactions" Style="{StaticResource FeatureTitleStyle}" DockPanel.Dock="Left"/>
                                                <TextBlock x:Name="UsageInteractionsText" Text="0" Style="{StaticResource StatNumberStyle}" FontSize="18" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                                            </DockPanel>
                                        </Border>
                                        <Border Style="{StaticResource SettingsRowCardStyle}">
                                            <DockPanel>
                                                <TextBlock Text="Claude Requests" Style="{StaticResource FeatureTitleStyle}" DockPanel.Dock="Left"/>
                                                <TextBlock x:Name="UsageClaudeText" Text="0" Style="{StaticResource StatNumberStyle}" FontSize="18" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                                            </DockPanel>
                                        </Border>
                                        <Border Style="{StaticResource SettingsRowCardStyle}">
                                            <DockPanel>
                                                <TextBlock Text="STT Processing" Style="{StaticResource FeatureTitleStyle}" DockPanel.Dock="Left"/>
                                                <TextBlock x:Name="UsageSttText" Text="0s" Style="{StaticResource StatNumberStyle}" FontSize="18" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                                            </DockPanel>
                                        </Border>
                                        <Border Style="{StaticResource SettingsRowCardStyle}" BorderThickness="0">
                                            <DockPanel>
                                                <TextBlock Text="Voice Responses" Style="{StaticResource FeatureTitleStyle}" DockPanel.Dock="Left"/>
                                                <TextBlock x:Name="UsageTtsText" Text="0s" Style="{StaticResource StatNumberStyle}" FontSize="18" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                                            </DockPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- Page 2: Setup & Worker -->
                <TabItem>
                    <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
                        <Grid Style="{StaticResource PageContentStyle}">
                            <StackPanel>
                                <TextBlock Text="Setup &amp; Connection" Style="{StaticResource PageHeaderStyle}"/>
                                <TextBlock Text="Configure your private AI gateway and local behavior." Style="{StaticResource PageLeadStyle}"/>

                                <Border Style="{StaticResource PremiumCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Worker Configuration" Style="{StaticResource SectionHeaderStyle}"/>
                                        <TextBlock Text="PointyPal routes all AI requests through your private Worker for privacy." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,20"/>
                                        
                                        <Grid Margin="0,0,0,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,10,0">
                                                <TextBlock Text="Worker Base URL" Style="{StaticResource MutedTextStyle}" Margin="0,0,0,8"/>
                                                <TextBox x:Name="AdvancedWorkerUrlBox"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Client Key" Style="{StaticResource MutedTextStyle}" Margin="0,0,0,8"/>
                                                <PasswordBox x:Name="AdvancedWorkerKeyBox"/>
                                            </StackPanel>
                                        </Grid>

                                        <DockPanel>
                                            <Button x:Name="CheckWorkerBtn" Content="Check Connection" Style="{StaticResource PrimaryButtonStyle}" Click="CheckWorkerBtn_Click" Margin="0,0,16,0"/>
                                            <TextBlock x:Name="WorkerStatusText" Text="Not Checked" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock x:Name="LastCheckTimeText" Text="" VerticalAlignment="Center" HorizontalAlignment="Right" Style="{StaticResource MutedTextStyle}"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PremiumCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Local Services" Style="{StaticResource SectionHeaderStyle}"/>
                                        <Border Style="{StaticResource SettingsRowCardStyle}">
                                            <DockPanel>
                                                <StackPanel DockPanel.Dock="Left">
                                                    <TextBlock Text="Voice Input (STT)" Style="{StaticResource FeatureTitleStyle}"/>
                                                    <TextBlock Text="Status of local microphone and speech processing." Style="{StaticResource MutedTextStyle}"/>
                                                </StackPanel>
                                                <TextBlock x:Name="SttStatusText" Text="READY" VerticalAlignment="Center" HorizontalAlignment="Right" DockPanel.Dock="Right" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                                            </DockPanel>
                                        </Border>
                                        <Border Style="{StaticResource SettingsRowCardStyle}">
                                            <DockPanel>
                                                <StackPanel DockPanel.Dock="Left">
                                                    <TextBlock Text="Voice Output (TTS)" Style="{StaticResource FeatureTitleStyle}"/>
                                                    <TextBlock Text="Status of AI response speech generation." Style="{StaticResource MutedTextStyle}"/>
                                                </StackPanel>
                                                <TextBlock x:Name="TtsStatusText" Text="READY" VerticalAlignment="Center" HorizontalAlignment="Right" DockPanel.Dock="Right" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                                            </DockPanel>
                                        </Border>
                                        <Border Style="{StaticResource SettingsRowCardStyle}" BorderThickness="0">
                                            <DockPanel>
                                                <StackPanel DockPanel.Dock="Left">
                                                    <TextBlock Text="AI Provider Status" Style="{StaticResource FeatureTitleStyle}"/>
                                                    <TextBlock Text="Connectivity to Claude / OpenAI via Worker." Style="{StaticResource MutedTextStyle}"/>
                                                </StackPanel>
                                                <TextBlock x:Name="AiStatusText" Text="OK" VerticalAlignment="Center" HorizontalAlignment="Right" DockPanel.Dock="Right" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                                            </DockPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Button Content="Re-run Setup Wizard" Style="{StaticResource GhostButtonStyle}" Click="OpenSetupWizard_Click" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- Page 3: Privacy & Data -->
                <TabItem>
                    <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
                        <Grid Style="{StaticResource PageContentStyle}">
                            <StackPanel>
                                <TextBlock Text="Privacy &amp; Data" Style="{StaticResource PageHeaderStyle}"/>
                                <TextBlock Text="Review and manage what is stored locally and what is sent to AI." Style="{StaticResource PageLeadStyle}"/>

                                <Border Style="{StaticResource PremiumCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Privacy Guard" Style="{StaticResource SectionHeaderStyle}"/>
                                        <Border Style="{StaticResource SettingsRowCardStyle}">
                                            <CheckBox x:Name="RedactDebugPayloadsCheck" Content="Redact sensitive data from debug logs"/>
                                        </Border>
                                        <Border Style="{StaticResource SettingsRowCardStyle}">
                                            <CheckBox x:Name="DisablePointerOnSensitiveWindowsCheck" Content="Auto-hide pointer on sensitive apps (Banking, etc)"/>
                                        </Border>
                                        <Border Style="{StaticResource SettingsRowCardStyle}" BorderThickness="0">
                                            <CheckBox x:Name="ConfirmScreenAsksCheck" Content="Always confirm before sending screenshot context"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PremiumCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Local Storage" Style="{StaticResource SectionHeaderStyle}"/>
                                        <Border Style="{StaticResource SettingsRowCardStyle}">
                                            <CheckBox x:Name="SaveInteractionHistoryCheck" Content="Keep interaction history (Local only)"/>
                                        </Border>
                                        <Border Style="{StaticResource SettingsRowCardStyle}">
                                            <CheckBox x:Name="SaveDebugArtifactsCheck" Content="Store debug artifacts for troubleshooting"/>
                                        </Border>
                                        <Border Style="{StaticResource SettingsRowCardStyle}" BorderThickness="0">
                                            <DockPanel>
                                                <StackPanel>
                                                    <TextBlock Text="Clear All Local Data" Style="{StaticResource FeatureTitleStyle}"/>
                                                    <TextBlock Text="Delete interaction history and cached artifacts." Style="{StaticResource MutedTextStyle}"/>
                                                </StackPanel>
                                                <Button Content="Clear Now" Style="{StaticResource GhostButtonStyle}" VerticalAlignment="Center" HorizontalAlignment="Right" DockPanel.Dock="Right" Click="ClearHistory_Click"/>
                                            </DockPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- Page 4: Hotkeys -->
                <TabItem>
                    <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
                        <Grid Style="{StaticResource PageContentStyle}">
                            <StackPanel>
                                <TextBlock Text="Hotkeys &amp; Shortcuts" Style="{StaticResource PageHeaderStyle}"/>
                                <TextBlock Text="Control PointyPal without leaving your active application." Style="{StaticResource PageLeadStyle}"/>

                                <UniformGrid Columns="2" Margin="-7,0,-7,20">
                                    <Border Style="{StaticResource FeatureCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Right Ctrl" Style="{StaticResource StatNumberStyle}" FontSize="24" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Voice Interaction" Style="{StaticResource FeatureTitleStyle}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Hold to talk, release to send." Style="{StaticResource MutedTextStyle}" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource FeatureCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Ctrl + Space" Style="{StaticResource StatNumberStyle}" FontSize="24" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Quick Ask Input" Style="{StaticResource FeatureTitleStyle}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Instant text-based questions." Style="{StaticResource MutedTextStyle}" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border Style="{StaticResource PremiumCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Global Hotkey Reference" Style="{StaticResource SectionHeaderStyle}"/>
                                        <ItemsControl x:Name="HelpHotkeysList">
                                            <!-- Logic populated items -->
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- Page 5: Advanced Tools -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TabControl x:Name="AdvancedTabs" Background="Transparent" BorderThickness="0" Padding="0">
                            <!-- Diagnostic Sub-tabs -->
                            <TabItem Header="Pointing Accuracy">
                                <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
                                    <Grid Style="{StaticResource PageContentStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Pointing Quality Diagnostics" Style="{StaticResource PageHeaderStyle}"/>
                                            <TextBlock Text="Verification of coordinate mapping and visual precision." Style="{StaticResource PageLeadStyle}"/>
                                            
                                            <UniformGrid Columns="3" Margin="-7,0,-7,18">
                                                <Border Style="{StaticResource StatCardStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="CORRECT" Style="{StaticResource StatLabelStyle}"/>
                                                        <TextBlock x:Name="PointingCorrectText" Text="0" Style="{StaticResource StatNumberStyle}"/>
                                                        <TextBlock Text="Exact targets hit" Style="{StaticResource MutedTextStyle}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource StatCardStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="CLOSE" Style="{StaticResource StatLabelStyle}"/>
                                                        <TextBlock x:Name="PointingCloseText" Text="0" Style="{StaticResource StatNumberStyle}"/>
                                                        <TextBlock Text="Within tolerance" Style="{StaticResource MutedTextStyle}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource StatCardStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="FAILED" Style="{StaticResource StatLabelStyle}"/>
                                                        <TextBlock x:Name="PointingWrongText" Text="0" Style="{StaticResource StatNumberStyle}"/>
                                                        <TextBlock Text="Out of bounds" Style="{StaticResource MutedTextStyle}"/>
                                                    </StackPanel>
                                                </Border>
                                            </UniformGrid>

                                            <Border Style="{StaticResource PremiumCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Calibration Status" Style="{StaticResource SectionHeaderStyle}"/>
                                                    <TextBlock x:Name="PointingRecommendationText" Text="Precision is high. No calibration needed." FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,14"/>
                                                    <TextBlock x:Name="PointingSampleSizeText" Text="Based on 0 interactions" Style="{StaticResource MutedTextStyle}"/>
                                                    <Button Content="Run Calibration Wizard" Style="{StaticResource PrimaryButtonStyle}" Click="OpenCalibration_Click" Margin="0,20,0,0" HorizontalAlignment="Left"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Performance">
                                <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
                                    <Grid Style="{StaticResource PageContentStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Latency Analysis" Style="{StaticResource PageHeaderStyle}"/>
                                            <TextBlock Text="Response times for end-to-end interactions." Style="{StaticResource PageLeadStyle}"/>

                                            <UniformGrid Columns="2" Margin="-7,0,-7,18">
                                                <Border Style="{StaticResource PremiumCardStyle}" Margin="7">
                                                    <StackPanel>
                                                        <TextBlock Text="Last Total Duration" Style="{StaticResource StatLabelStyle}"/>
                                                        <TextBlock x:Name="LastTotalDurationText" Text="0ms" Style="{StaticResource StatNumberStyle}"/>
                                                        <TextBlock x:Name="LastClaudeDurationText" Text="Claude: 0ms" Style="{StaticResource MutedTextStyle}"/>
                                                        <TextBlock x:Name="LastSttDurationText" Text="STT: 0ms" Style="{StaticResource MutedTextStyle}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource PremiumCardStyle}" Margin="7">
                                                    <StackPanel>
                                                        <TextBlock Text="P50 Latency (24h)" Style="{StaticResource StatLabelStyle}"/>
                                                        <TextBlock x:Name="P50DurationText" Text="0ms" Style="{StaticResource StatNumberStyle}"/>
                                                        <TextBlock Text="Slowest Component:" Style="{StaticResource MutedTextStyle}"/>
                                                        <TextBlock x:Name="SlowestStepText" Text="None" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </UniformGrid>

                                            <Button x:Name="RunLatencySelfTestBtn" Content="Run Latency Self-Test" Style="{StaticResource PrimaryButtonStyle}" Click="RunLatencySelfTestBtn_Click" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="System Health">
                                <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
                                    <Grid Style="{StaticResource PageContentStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Internal System Health" Style="{StaticResource PageHeaderStyle}"/>
                                            <TextBlock Text="Log inspection and component validation." Style="{StaticResource PageLeadStyle}"/>

                                            <Border Style="{StaticResource PremiumCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Active Log Path" Style="{StaticResource SectionHeaderStyle}"/>
                                                    <TextBox x:Name="AppLogPathText" IsReadOnly="True" Margin="0,0,0,14"/>
                                                    <Button Content="Open Log Directory" Style="{StaticResource GhostButtonStyle}" Click="OpenLogFolder_Click" HorizontalAlignment="Left"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource PremiumCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Preflight Validation" Style="{StaticResource SectionHeaderStyle}"/>
                                                    <TextBlock x:Name="PreflightOverallStatusText" Text="NOT RUN" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                    <Button x:Name="RunPreflightBtn" Content="Run Preflight Checks" Style="{StaticResource PrimaryButtonStyle}" Click="RunPreflightBtn_Click" HorizontalAlignment="Left" Margin="0,0,0,14"/>
                                                    <ItemsControl x:Name="PreflightResultsList">
                                                        <!-- Populate via logic -->
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource PremiumCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Self-Test Suite" Style="{StaticResource SectionHeaderStyle}"/>
                                                    <Grid Margin="0,0,0,20">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="LAST STATUS" Style="{StaticResource StatLabelStyle}"/>
                                                            <TextBlock x:Name="SelfTestStatusText" Text="NONE" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="LAST RUN" Style="{StaticResource StatLabelStyle}"/>
                                                            <TextBlock x:Name="SelfTestLastRunText" Text="Never" Style="{StaticResource MutedTextStyle}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="COVERAGE" Style="{StaticResource StatLabelStyle}"/>
                                                            <TextBlock x:Name="SelfTestScenarioCountText" Text="24 scenarios" Style="{StaticResource MutedTextStyle}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    
                                                    <TextBlock x:Name="SelfTestReportPathText" Text="" Style="{StaticResource MutedTextStyle}" Margin="0,0,0,20"/>

                                                    <StackPanel Orientation="Horizontal">
                                                        <Button x:Name="RunQuickSelfTestBtn" Content="Run Quick Test" Style="{StaticResource PrimaryButtonStyle}" Click="RunQuickSelfTestBtn_Click" Margin="0,0,10,0"/>
                                                        <Button x:Name="RunFullValidationBtn" Content="Run Full Validation" Style="{StaticResource SecondaryButtonStyle}" Click="RunFullValidationBtn_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem x:Name="RecoveryTab" Header="Resilience">
                                <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
                                    <Grid Style="{StaticResource PageContentStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Resilience &amp; Recovery" Style="{StaticResource PageHeaderStyle}"/>
                                            <TextBlock Text="Guard rails and soak testing tools." Style="{StaticResource PageLeadStyle}"/>

                                            <UniformGrid Columns="2" Margin="-7,0,-7,18">
                                                <Border Style="{StaticResource PremiumCardStyle}" Margin="7">
                                                    <StackPanel>
                                                        <TextBlock Text="Recovery Status" Style="{StaticResource StatLabelStyle}"/>
                                                        <TextBlock x:Name="ResilienceStatusText" Text="Healthy" Style="{StaticResource StatNumberStyle}" FontSize="24" Foreground="{StaticResource SuccessBrush}"/>
                                                        <TextBlock Text="Auto-restart enabled" Style="{StaticResource MutedTextStyle}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource PremiumCardStyle}" Margin="7">
                                                    <StackPanel>
                                                        <TextBlock Text="Memory usage" Style="{StaticResource StatLabelStyle}"/>
                                                        <TextBlock x:Name="ResilienceMemoryText" Text="142MB" Style="{StaticResource StatNumberStyle}" FontSize="24"/>
                                                        <TextBlock Text="Peak: 210MB" Style="{StaticResource MutedTextStyle}"/>
                                                    </StackPanel>
                                                </Border>
                                            </UniformGrid>

                                            <Border Style="{StaticResource PremiumCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Soak Test Utility" Style="{StaticResource SectionHeaderStyle}"/>
                                                    <TextBlock Text="Simulates heavy interaction patterns to detect leaks or crashes." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,20"/>
                                                    
                                                    <TextBlock x:Name="SoakStatusText" Text="Status: Idle" FontWeight="SemiBold" Margin="0,0,0,16"/>
                                                    
                                                    <UniformGrid Columns="2">
                                                        <StackPanel Margin="0,0,10,0">
                                                            <TextBlock Text="Duration (iterations)" Style="{StaticResource MutedTextStyle}" Margin="0,0,0,5"/>
                                                            <TextBox x:Name="SoakDurationBox" Text="10"/>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Text="Interval (ms)" Style="{StaticResource MutedTextStyle}" Margin="0,0,0,5"/>
                                                            <TextBox x:Name="SoakIntervalBox" Text="1000"/>
                                                        </StackPanel>
                                                    </UniformGrid>
                                                    
                                                    <WrapPanel Margin="0,20,0,0">
                                                        <Button x:Name="RunSoakTestBtn" Content="Start Test" Style="{StaticResource PrimaryButtonStyle}" Click="RunSoakTestBtn_Click" Margin="0,0,10,0"/>
                                                        <Button x:Name="OpenSoakReportBtn" Content="View Results" Style="{StaticResource GhostButtonStyle}" Click="OpenSoakReportBtn_Click" Margin="0,0,10,0"/>
                                                        <Button x:Name="ClearResilienceEventsBtn" Content="Clear History" Style="{StaticResource GhostButtonStyle}" Click="ClearResilienceEventsBtn_Click"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                        
                        <Button Grid.Row="1" x:Name="HideAdvancedBtn" Content="Hide Advanced Tools" Click="HideAdvancedBtn_Click" Margin="24" Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Right"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CommandBarStyle}">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ReloadBtn" Content="Reload" Style="{StaticResource GhostButtonStyle}" Click="ReloadBtn_Click" Margin="0,0,12,0"/>
                    <Button Content="User Guides" Style="{StaticResource GhostButtonStyle}" Click="OpenDoc_Click" Tag="docs/index.md" Margin="0,0,12,0"/>
                    <TextBlock x:Name="LastTimelineReasonText" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}" Margin="20,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button x:Name="OpenDebugBtn" Content="Debug Logs" Style="{StaticResource GhostButtonStyle}" Click="OpenDebugBtn_Click" Margin="0,0,12,0"/>
                    <Button x:Name="SaveBtn" Content="Save Changes" Style="{StaticResource PrimaryButtonStyle}" Click="SaveBtn_Click" Padding="30,10"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
