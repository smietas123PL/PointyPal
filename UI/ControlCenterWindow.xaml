                            <ItemsControl x:Name="ReadinessWarningsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#856404" Margin="0,2" TextWrapping="Wrap">
                                            <Run Text="⚠️ "/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="2" Header="Recommended Actions">
                        <ItemsControl x:Name="ReadinessActionsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Margin="0,2" TextWrapping="Wrap">
                                        <Run Text="👉 "/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>

                    <WrapPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,10">
                        <Button x:Name="RunReadinessBtn" Content="Run RC Readiness Check" Click="RunReadinessBtn_Click" Margin="5" Padding="15,8" Background="#0071E3" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        <Button x:Name="RunFullValidationBtn" Content="Run Full RC Validation" Click="RunFullValidationBtn_Click" Margin="5" Padding="15,8" Background="#34C759" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        <Button x:Name="ExportReadinessBtn" Content="Export RC Readiness Report" Click="ExportReadinessBtn_Click" Margin="5" Padding="10,5"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
            
            <!-- Legacy Preflight (Optional) -->
            <TabItem x:Name="PreflightDetailsTab" Header="Preflight Details">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <GroupBox Grid.Row="0" Header="Raw Preflight Status">
                        <StackPanel>
                            <DockPanel Margin="0,5">
                                <Label Content="Overall Status:"/>
                                <TextBlock x:Name="PreflightOverallStatusText" Text="Not run" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                            </DockPanel>
                            <DockPanel Margin="0,5">
                                <Label Content="Last Run:"/>
                                <TextBlock x:Name="PreflightLastRunText" Text="-" VerticalAlignment="Center"/>
                            </DockPanel>
                            <DockPanel Margin="0,5">
                                <Label Content="Duration:"/>
                                <TextBlock x:Name="PreflightDurationText" Text="-" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>
                    <ListView Grid.Row="1" x:Name="PreflightResultsList" Margin="0,10">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Check" DisplayMemberBinding="{Binding Name}" Width="150"/>
                                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="80"/>
                                <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="400"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <WrapPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,10">
                        <Button x:Name="RunPreflightBtn" Content="Run Preflight Check" Click="RunPreflightBtn_Click" Margin="5" Padding="10,5"/>
                        <Button x:Name="ExportPreflightBtn" Content="Export Report" Click="ExportPreflightBtn_Click" Margin="5" Padding="10,5"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <!-- Recovery -->
            <TabItem x:Name="RecoveryTab" Header="Recovery">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel>
                        <GroupBox Header="Config Backups">
                            <StackPanel>
                                <DockPanel Margin="0,5">
                                    <Label Content="Backup Count:"/>
                                    <TextBlock x:Name="BackupCountText" Text="0" VerticalAlignment="Center"/>
                                </DockPanel>
                                <DockPanel Margin="0,5">
                                    <Label Content="Latest Backup:"/>
                                    <TextBlock x:Name="LatestBackupText" Text="None" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </DockPanel>
                                <WrapPanel Margin="0,10,0,0">
                                    <Button x:Name="BackupNowBtn" Content="Backup Config Now" Click="BackupNowBtn_Click" Margin="5" Padding="10,5"/>
                                    <Button x:Name="RestoreLatestBtn" Content="Restore Latest Backup" Click="RestoreLatestBtn_Click" Margin="5" Padding="10,5"/>
                                    <Button x:Name="OpenBackupsFolderBtn" Content="Open Backups Folder" Click="OpenBackupsFolderBtn_Click" Margin="5" Padding="10,5"/>
                                </WrapPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Local Data Cleanup">
                            <StackPanel>
                                <WrapPanel>
                                    <Button x:Name="ClearDebugFilesBtn" Content="Clear Debug Files" Click="ClearDebugFilesBtn_Click" Margin="5" Padding="10,5"/>
                                    <Button x:Name="ClearInteractionHistoryBtn" Content="Clear Interaction History" Click="ClearInteractionHistoryBtn_Click" Margin="5" Padding="10,5"/>
                                    <Button x:Name="ClearUsageDataBtn" Content="Clear Usage Data" Click="ClearUsageDataBtn_Click" Margin="5" Padding="10,5"/>
                                    <Button x:Name="ClearTimelineHistoryBtn2" Content="Clear Timeline History" Click="ClearTimelineHistoryBtn_Click" Margin="5" Padding="10,5"/>
                                    <Button x:Name="ClearPointingFeedbackBtn" Content="Clear Pointing Feedback" Click="ClearPointingFeedbackBtn_Click" Margin="5" Padding="10,5"/>
                                </WrapPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Config Export/Import">
                            <StackPanel>
                                <WrapPanel>
                                    <Button x:Name="ExportBundleBtn" Content="Export Config Bundle" Click="ExportBundleBtn_Click" Margin="5" Padding="10,5"/>
                                    <Button x:Name="ImportBundleBtn" Content="Import Config Bundle" Click="ImportBundleBtn_Click" Margin="5" Padding="10,5"/>
                                </WrapPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Factory Reset" BorderBrush="#D70015">
                            <StackPanel>
                                <TextBlock Text="Clears all logs, history, usage, and resets configuration to defaults." Foreground="#D70015" TextWrapping="Wrap" Margin="5,0,0,10"/>
                                <Button x:Name="FactoryResetBtn" Content="Factory Reset Local State" Click="FactoryResetBtn_Click" Margin="5" Padding="20,8" Background="#D70015" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="#FFFFFF" Padding="15" CornerRadius="8" Effect="{StaticResource PremiumShadow}">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ResetBtn" Content="Reset to Defaults" Click="ResetBtn_Click" Margin="0,0,10,0" Padding="10,5"/>
                    <Button x:Name="ReloadBtn" Content="Reload" Click="ReloadBtn_Click" Margin="0,0,10,0" Padding="10,5"/>
                    <Button x:Name="OpenReleaseGuideBtn" Content="Release Guide" Click="OpenDoc_Click" Tag="docs/local-release.md" Margin="0,0,5,0" Padding="8,4"/>
                    <Button x:Name="OpenRecoveryGuideBtn" Content="Recovery Guide" Click="OpenDoc_Click" Tag="docs/recovery.md" Margin="0,0,5,0" Padding="8,4"/>
                    <Button x:Name="OpenRcChecklistBtn" Content="RC Checklist" Click="OpenDoc_Click" Tag="docs/rc-checklist.md" Margin="0,0,5,0" Padding="8,4"/>
                    <TextBlock Text="* Some settings may require restart" VerticalAlignment="Center" Foreground="#86868B" FontSize="10" Margin="10,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="OpenConfigBtn" Content="Open Config File" Click="OpenConfigBtn_Click" Margin="0,0,10,0" Padding="10,5"/>
                    <Button x:Name="OpenDebugBtn" Content="Open Debug Folder" Click="OpenDebugBtn_Click" Margin="0,0,10,0" Padding="10,5"/>
                    <Button x:Name="SaveBtn" Content="Save Settings" Click="SaveBtn_Click" Padding="20,5" Background="#0071E3" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
