<UserControl x:Class="PointyPal.UI.Controls.ConcentricCircles"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="96"
             d:DesignWidth="96">

    <UserControl.Resources>
        <!-- Outer ring: 2s, scale 1→1.2→1, opacity 0.3→0.1→0.3 -->
        <Storyboard x:Key="OuterRingPulse" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="OuterRingScale"
                                           Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1.2">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="OuterRingScale"
                                           Storyboard.TargetProperty="ScaleY">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1.2">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="OuterRing"
                                           Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="0.3"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="0.1">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="0.3">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Middle ring: 2s, scale 1→1.15→1, opacity 0.5→0.2→0.5 -->
        <Storyboard x:Key="MiddleRingPulse" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MiddleRingScale"
                                           Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1.15">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MiddleRingScale"
                                           Storyboard.TargetProperty="ScaleY">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1.15">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MiddleRing"
                                           Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="0.2">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="0.5">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource OuterRingPulse}"/>
            <BeginStoryboard Storyboard="{StaticResource MiddleRingPulse}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <!-- Grid sized 96x96 by default, scales with Width/Height from parent -->
    <Grid>
        <!-- Outer ring: border #22D3EE/30, pulsing -->
        <Ellipse x:Name="OuterRing"
                 Stroke="{StaticResource AccentBorderBrush}"
                 StrokeThickness="2"
                 Fill="Transparent"
                 Opacity="0.3"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="OuterRingScale" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Middle ring: border #22D3EE/50, pulsing -->
        <Ellipse x:Name="MiddleRing"
                 Stroke="{StaticResource AccentBorderStrongBrush}"
                 StrokeThickness="2"
                 Fill="Transparent"
                 Margin="8"
                 Opacity="0.5"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="MiddleRingScale" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Inner filled circle: gradient cyan→violet with label -->
        <Border Margin="16"
                CornerRadius="99"
                Background="{StaticResource CoreNodeGradientBrush}"
                Effect="{StaticResource CyanGlowSoftEffect}">
            <TextBlock x:Name="LabelText"
                       Text=""
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#1A1D23"/>
        </Border>
    </Grid>
</UserControl>
