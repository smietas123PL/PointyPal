<UserControl x:Class="PointyPal.UI.Controls.CoreNodeVisual"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="180"
             d:DesignWidth="180">

    <UserControl.Resources>
        <!-- Outer glow gradient: cyan → violet (matches DiamondAvatar outer glow) -->
        <LinearGradientBrush x:Key="OuterGlowPulseGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#22D3EE" Offset="0"/>
            <GradientStop Color="#6366F1" Offset="1"/>
        </LinearGradientBrush>

        <!-- 3s breathing: scale 1→1.1→1, opacity 0.4→0.7→0.4 -->
        <Storyboard x:Key="OuterGlowPulse" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="OuterGlow"
                                           Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="0.40"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="0.70">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:3.0" Value="0.40">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="OuterGlowScaleX"
                                           Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:3.0" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="OuterGlowScaleX"
                                           Storyboard.TargetProperty="ScaleY">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:3.0" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- 2s center spot: scale 1→1.3→1, opacity 0.5→0.8→0.5 -->
        <Storyboard x:Key="CenterSpotPulse" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterSpot"
                                           Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="0.50"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="0.80">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="0.50">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterSpotScaleX"
                                           Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1.3">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterSpotScaleX"
                                           Storyboard.TargetProperty="ScaleY">
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1.3">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource OuterGlowPulse}"/>
            <BeginStoryboard Storyboard="{StaticResource CenterSpotPulse}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Width="180" Height="180">
        <!-- Outer glow: cyan→violet gradient blur, 3s breathing pulse -->
        <Ellipse x:Name="OuterGlow"
                 Width="150" Height="150"
                 Fill="{StaticResource OuterGlowPulseGradientBrush}"
                 Opacity="0.40"
                 RenderTransformOrigin="0.5,0.5"
                 Effect="{StaticResource CyanGlowSoftEffect}">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="OuterGlowScaleX" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Diamond body: gradient #22D3EE→#6366F1 at 45° rotation, 30% border-radius -->
        <Border Width="116" Height="116"
                CornerRadius="34"
                Background="{StaticResource CoreNodeGradientBrush}"
                Opacity="0.94"
                Effect="{StaticResource CyanGlowEffect}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <RotateTransform Angle="45"/>
            </Border.RenderTransform>
        </Border>

        <!-- Inner translucent layer: ~40% opacity -->
        <Border Width="84" Height="84"
                CornerRadius="26"
                Background="{StaticResource CoreNodeInnerBrush}"
                Opacity="0.86"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <RotateTransform Angle="45"/>
            </Border.RenderTransform>
        </Border>

        <!-- Center light spot: cyan, 2s pulse (scale 1→1.3→1, opacity 0.5→0.8→0.5) -->
        <Ellipse x:Name="CenterSpot"
                 Width="34" Height="34"
                 Fill="{StaticResource CyanAccentSoftBrush}"
                 Opacity="0.50"
                 RenderTransformOrigin="0.5,0.5"
                 Effect="{StaticResource CyanGlowEffect}">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="CenterSpotScaleX" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>
    </Grid>
</UserControl>
