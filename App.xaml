<Application x:Class="PointyPal.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PointyPal"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="UI/Styles/ThemeTokens.xaml"/>
                <ResourceDictionary Source="UI/Styles/Brushes.xaml"/>
                <ResourceDictionary Source="UI/Styles/Typography.xaml"/>
                <ResourceDictionary Source="UI/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="UI/Styles/CardStyles.xaml"/>
                <ResourceDictionary Source="UI/Styles/NavigationStyles.xaml"/>
                <ResourceDictionary Source="UI/Styles/ControlCenterStyles.xaml"/>
                <ResourceDictionary Source="UI/Styles/QuickAskStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
