<Window x:Class="PointyPal.Overlay.CalibrationOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibration Grid"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Focusable="False"
        WindowState="Maximized">
    <Grid Name="MainGrid">
        <Canvas Name="GridCanvas" IsHitTestVisible="False" Opacity="0.6">
            <!-- Grid lines will be drawn here -->
        </Canvas>
        
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20" IsHitTestVisible="False">
            <Border Background="#CC000000" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="CALIBRATION MODE" Foreground="#FFFFD700" FontWeight="Bold" FontSize="16" Margin="0,0,0,5" />
                    <TextBlock Name="ScreenCoordsText" Text="Screen: 0, 0" Foreground="White" FontFamily="Consolas" />
                    <TextBlock Name="ImageCoordsText" Text="Image: 0, 0" Foreground="#00FF00" FontFamily="Consolas" />
                    <TextBlock Text="Press ESC or Ctrl+Shift+F9 to exit" Foreground="#AAAAAA" FontSize="11" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
