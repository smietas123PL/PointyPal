<UserControl x:Class="PointyPal.Overlay.PointerVisualControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="Auto" Height="Auto">
    <UserControl.Resources>
        <!-- Gradients -->
        <LinearGradientBrush x:Key="MainFillBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="White" Offset="0"/>
            <GradientStop Color="#DBEAFE" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="MainStrokeBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8B5CF6" Offset="0"/>
            <GradientStop Color="#60A5FA" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- Animations -->
        <Storyboard x:Key="BobAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="TriangleGrid" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-2" Duration="0:0:1" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseInOut" Exponent="3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="Aura" 
                             Storyboard.TargetProperty="Opacity"
                             From="0.05" To="0.25" Duration="0:0:0.5" AutoReverse="True" />
            <DoubleAnimation Storyboard.TargetName="AuraScale" 
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.15" Duration="0:0:0.5" AutoReverse="True" />
            <DoubleAnimation Storyboard.TargetName="AuraScale" 
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.15" Duration="0:0:0.5" AutoReverse="True" />
        </Storyboard>

        <Storyboard x:Key="SpinnerAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinnerRotate" 
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:0.95" />
        </Storyboard>

        <Storyboard x:Key="BarsAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="Bar1" Storyboard.TargetProperty="Height" From="4" To="12" Duration="0:0:0.35" AutoReverse="True" />
            <DoubleAnimation Storyboard.TargetName="Bar2" Storyboard.TargetProperty="Height" From="4" To="12" Duration="0:0:0.35" AutoReverse="True" BeginTime="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetName="Bar3" Storyboard.TargetProperty="Height" From="4" To="12" Duration="0:0:0.35" AutoReverse="True" BeginTime="0:0:0.24" />
        </Storyboard>

        <Storyboard x:Key="SpeakAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpeakBar1" Storyboard.TargetProperty="Height" From="4" To="12" Duration="0:0:0.27" AutoReverse="True" />
            <DoubleAnimation Storyboard.TargetName="SpeakBar2" Storyboard.TargetProperty="Height" From="4" To="12" Duration="0:0:0.27" AutoReverse="True" BeginTime="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetName="SpeakBar3" Storyboard.TargetProperty="Height" From="4" To="12" Duration="0:0:0.27" AutoReverse="True" BeginTime="0:0:0.24" />
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="ScalingContainer">
        <Grid.LayoutTransform>
            <ScaleTransform x:Name="GlobalScale" ScaleX="1" ScaleY="1" />
        </Grid.LayoutTransform>
        
        <Grid x:Name="MainGrid" Width="64" Height="80">
            <!-- Aura -->
            <Ellipse x:Name="Aura" Width="46" Height="46" Margin="8,8,10,26" 
                     Opacity="0" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4D60A5FA" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="0.8"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="4"/>
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="AuraScale" CenterX="23" CenterY="23"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Triangle Pointer -->
            <Grid x:Name="TriangleGrid" Width="48" Height="48" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,8,0,0">
                <Grid.RenderTransform>
                    <TranslateTransform Y="0"/>
                </Grid.RenderTransform>
                
                <Canvas Width="64" Height="64" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Canvas.RenderTransform>
                        <ScaleTransform ScaleX="0.75" ScaleY="0.75"/>
                    </Canvas.RenderTransform>
                    
                    <!-- Shadow -->
                    <Path Data="M8 4 C8 2.4 9.8 1.5 11.2 2.3 L57 28.7 C58.8 29.8 58.4 32.5 56.4 33 L35 38.2 L23.8 59 C22.8 60.8 20.1 60.3 19.7 58.2 L8 4 Z"
                          Fill="Black" Opacity="0.2">
                        <Path.RenderTransform>
                            <TranslateTransform X="0" Y="2"/>
                        </Path.RenderTransform>
                        <Path.Effect>
                            <BlurEffect Radius="4"/>
                        </Path.Effect>
                    </Path>

                    <!-- Main Triangle -->
                    <Path x:Name="PointerShape"
                          Data="M8 4 C8 2.4 9.8 1.5 11.2 2.3 L57 28.7 C58.8 29.8 58.4 32.5 56.4 33 L35 38.2 L23.8 59 C22.8 60.8 20.1 60.3 19.7 58.2 L8 4 Z"
                          Fill="{StaticResource MainFillBrush}"
                          Stroke="{StaticResource MainStrokeBrush}"
                          StrokeThickness="3.6"
                          StrokeLineJoin="Round"/>
                    
                    <!-- Highlight Stroke 1 -->
                    <Path Data="M13 8.5 L51 29.8"
                          Stroke="White"
                          StrokeThickness="2.1"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Opacity="0.9"/>
                    
                    <!-- Highlight Stroke 2 -->
                    <Path Data="M28 34 L22 56"
                          Stroke="#60A5FA"
                          StrokeThickness="2.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Opacity="0.55"/>
                </Canvas>
            </Grid>

            <!-- Status Slot -->
            <Grid x:Name="StatusSlot" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30,44,0,0" Height="16">
                <Grid.LayoutTransform>
                    <ScaleTransform x:Name="StatusScale" ScaleX="1.15" ScaleY="1.15" />
                </Grid.LayoutTransform>
                
                <!-- Listening Bars -->
                <StackPanel x:Name="ListeningBars" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Bottom">
                    <Rectangle x:Name="Bar1" Width="4" Height="4" RadiusX="2" RadiusY="2" Fill="#8B5CF6" Margin="0,0,2,0"/>
                    <Rectangle x:Name="Bar2" Width="4" Height="4" RadiusX="2" RadiusY="2" Fill="#8B5CF6" Margin="0,0,2,0"/>
                    <Rectangle x:Name="Bar3" Width="4" Height="4" RadiusX="2" RadiusY="2" Fill="#8B5CF6" Margin="0,0,2,0"/>
                </StackPanel>

                <!-- Spinner -->
                <Grid x:Name="ProcessingSpinner" Width="16" Height="16" Visibility="Collapsed">
                    <Ellipse StrokeThickness="2">
                        <Ellipse.Stroke>
                            <SolidColorBrush Color="#94A3B8" Opacity="0.13"/>
                        </Ellipse.Stroke>
                    </Ellipse>
                    <Path Data="M8 0 A8 8 0 0 1 16 8" Stroke="#60A5FA" StrokeThickness="2" StrokeStartLineCap="Round"/>
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" CenterX="8" CenterY="8"/>
                    </Grid.RenderTransform>
                </Grid>

                <!-- Speaking Bars -->
                <StackPanel x:Name="SpeakingBars" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Bottom">
                    <Rectangle x:Name="SpeakBar1" Width="4" Height="4" RadiusX="2" RadiusY="2" Fill="#60A5FA" Margin="0,0,2,0"/>
                    <Rectangle x:Name="SpeakBar2" Width="4" Height="4" RadiusX="2" RadiusY="2" Fill="#60A5FA" Margin="0,0,2,0"/>
                    <Rectangle x:Name="SpeakBar3" Width="4" Height="4" RadiusX="2" RadiusY="2" Fill="#60A5FA" Margin="0,0,2,0"/>
                </StackPanel>

                <!-- Error Badge -->
                <Border x:Name="ErrorBadge" Width="16" Height="16" CornerRadius="8" Background="#EF4444" Visibility="Collapsed">
                    <TextBlock Text="!" Foreground="White" FontSize="10" FontWeight="ExtraBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                </Border>

                <!-- Safe Mode Badge -->
                <Border x:Name="SafeBadge" Width="16" Height="16" CornerRadius="8" BorderThickness="1" Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#F59E0B" Opacity="0.10"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#F59E0B" Opacity="0.55"/>
                    </Border.BorderBrush>
                    <TextBlock Text="!" Foreground="#F59E0B" FontSize="10" FontWeight="ExtraBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                </Border>

                <!-- Developer Badge -->
                <Border x:Name="DevBadge" Height="16" Padding="5,0" CornerRadius="4" Background="#111827" BorderThickness="1" Visibility="Collapsed">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#FFFFFF" Opacity="0.15"/>
                    </Border.BorderBrush>
                    <TextBlock Text="DEV" Foreground="White" FontSize="9" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
